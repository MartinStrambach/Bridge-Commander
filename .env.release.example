# Copy this file to .env.release and fill in your values.
# .env.release is gitignored.

# Exact name of your Developer ID Application certificate as it appears in
# `security find-identity -p codesigning -v` (include the parenthesized team ID).
DEVELOPER_ID_APPLICATION="Developer ID Application: Your Name (TEAMID)"

# Your Apple Developer Team ID (10 characters).
APPLE_TEAM_ID="TEAMID"

# Name of the notarytool keychain profile. Create it once with:
#   xcrun notarytool store-credentials bridge-commander-notary \
#     --apple-id <your-apple-id> --team-id $APPLE_TEAM_ID
NOTARY_PROFILE="bridge-commander-notary"
